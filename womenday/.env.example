# Vercel: set these in Project Settings → Environment Variables.
# Optional: only needed if you use Supabase or a custom base path.
# If deploying from repo root, set Root Directory to "womenday" in Vercel.

# Base path for app (default: /). Use e.g. "/womenday/" for subpath deployment.
# VITE_BASE_PATH=/

# Supabase (when using @supabase/supabase-js)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
